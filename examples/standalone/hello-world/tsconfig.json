{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "plugins": [{ "name": "typesugar/language-service" }]
  },
  "include": ["src/**/*"]
}
