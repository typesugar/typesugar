{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "plugins": [{ "transform": "@typesugar/transformer" }]
  },
  "include": ["src"]
}
