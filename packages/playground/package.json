{
  "name": "@typesugar/playground",
  "version": "0.1.0",
  "description": "🧊 Browser-compatible typesugar bundle for the interactive playground",
  "author": "Dean Povey <dean.povey@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/typesugar/typesugar.git",
    "directory": "packages/playground"
  },
  "homepage": "https://github.com/typesugar/typesugar/tree/main/packages/playground#readme",
  "bugs": {
    "url": "https://github.com/typesugar/typesugar/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/browser.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "typescript",
    "macros",
    "playground",
    "browser",
    "interactive"
  ],
  "dependencies": {
    "@typesugar/core": "workspace:*",
    "@typesugar/macros": "workspace:*",
    "@typesugar/preprocessor": "workspace:*",
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "tsup": "^8.5.1",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false
}
