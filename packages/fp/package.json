{
  "name": "@typesugar/fp",
  "version": "0.1.1",
  "description": "🧊 Functional programming library with typeclasses and data types for typesugar",
  "author": "Dean Povey <dean.povey@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/typesugar/typesugar.git",
    "directory": "packages/fp"
  },
  "homepage": "https://github.com/typesugar/typesugar/tree/main/packages/fp#readme",
  "bugs": {
    "url": "https://github.com/typesugar/typesugar/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js",
      "require": "./dist/data/index.cjs"
    },
    "./data/either": {
      "types": "./dist/data/either.d.ts",
      "import": "./dist/data/either.js",
      "require": "./dist/data/either.cjs"
    },
    "./io": {
      "types": "./dist/io/index.d.ts",
      "import": "./dist/io/index.js",
      "require": "./dist/io/index.cjs"
    },
    "./typeclasses": {
      "types": "./dist/typeclasses/index.d.ts",
      "import": "./dist/typeclasses/index.js",
      "require": "./dist/typeclasses/index.cjs"
    },
    "./syntax": {
      "types": "./dist/syntax/index.d.ts",
      "import": "./dist/syntax/index.js",
      "require": "./dist/syntax/index.cjs"
    },
    "./effect": {
      "types": "./dist/effect/index.d.ts",
      "import": "./dist/effect/index.js",
      "require": "./dist/effect/index.cjs"
    },
    "./zero-cost": {
      "types": "./dist/zero-cost/index.d.ts",
      "import": "./dist/zero-cost/index.js",
      "require": "./dist/zero-cost/index.cjs"
    },
    "./macros": {
      "types": "./dist/macros.d.ts",
      "import": "./dist/macros.js",
      "require": "./dist/macros.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "typesugar": {
    "macros": "./macros"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:watch": "tsup --watch",
    "build:dts": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "typescript",
    "macros",
    "functional-programming",
    "fp",
    "typeclasses",
    "monad"
  ],
  "dependencies": {
    "@typesugar/contracts": "workspace:*",
    "@typesugar/core": "workspace:*",
    "@typesugar/macros": "workspace:*",
    "@typesugar/type-system": "workspace:*"
  },
  "devDependencies": {
    "unplugin-typesugar": "workspace:*"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": true
}
