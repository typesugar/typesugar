{
  "name": "typesugar-vscode",
  "version": "0.1.1-rc.0",
  "description": "🧊 IDE support for typesugar — syntax highlighting, expansion preview, and diagnostics for compile-time macros",
  "author": "Dean Povey <dean.povey@gmail.com>",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/typesugar/typesugar.git",
    "directory": "packages/vscode"
  },
  "homepage": "https://github.com/typesugar/typesugar/tree/main/packages/vscode#readme",
  "bugs": {
    "url": "https://github.com/typesugar/typesugar/issues"
  },
  "license": "MIT",
  "displayName": "typesugar",
  "publisher": "typesugar",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/typesugar.manifest.json",
    "workspaceContains:**/node_modules/typesugar",
    "onLanguage:sugared-typescript",
    "onLanguage:sugared-typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sugared-typescript",
        "aliases": [
          "Sugared TypeScript",
          "STS"
        ],
        "extensions": [
          ".sts"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/sts-light.svg",
          "dark": "./icons/sts-dark.svg"
        }
      },
      {
        "id": "sugared-typescriptreact",
        "aliases": [
          "Sugared TypeScript React",
          "STSX"
        ],
        "extensions": [
          ".stsx"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/stsx-light.svg",
          "dark": "./icons/stsx-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "sugared-typescript",
        "scopeName": "source.sts",
        "path": "./syntaxes/sts.tmLanguage.json"
      },
      {
        "language": "sugared-typescriptreact",
        "scopeName": "source.stsx",
        "path": "./syntaxes/stsx.tmLanguage.json"
      },
      {
        "scopeName": "source.ts.typesugar",
        "path": "./syntaxes/typesugar.tmLanguage.json",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.sts",
          "source.stsx"
        ]
      },
      {
        "scopeName": "source.ts.typesugar.units",
        "path": "./syntaxes/typesugar-units.tmLanguage.json",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.sts",
          "source.stsx"
        ]
      },
      {
        "scopeName": "source.sts.sugared-syntax",
        "path": "./syntaxes/sts-sugared.tmLanguage.json",
        "injectTo": [
          "source.sts",
          "source.stsx"
        ]
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "macro",
        "superType": "function",
        "description": "A compile-time macro invocation"
      },
      {
        "id": "macroDecorator",
        "superType": "decorator",
        "description": "A compile-time macro decorator"
      },
      {
        "id": "macroTemplate",
        "superType": "function",
        "description": "A tagged template macro tag"
      },
      {
        "id": "extensionMethod",
        "superType": "method",
        "description": "An implicit typeclass extension method"
      },
      {
        "id": "deriveArg",
        "superType": "type",
        "description": "A derive macro argument (e.g., Eq, Ord)"
      },
      {
        "id": "bindVariable",
        "superType": "variable",
        "description": "A monadic bind variable in a comprehension"
      },
      {
        "id": "comptimeBlock",
        "superType": "function",
        "description": "A compile-time evaluation block"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "macro",
        "description": "Indicates a macro-related token"
      },
      {
        "id": "comptime",
        "description": "Indicates compile-time evaluation"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "typescript",
        "scopes": {
          "macro": [
            "entity.name.function.macro.typesugar"
          ],
          "macroDecorator": [
            "entity.name.function.decorator.macro.typesugar"
          ],
          "macroTemplate": [
            "entity.name.tag.macro.typesugar"
          ],
          "extensionMethod": [
            "entity.name.function.extension.typesugar"
          ],
          "deriveArg": [
            "entity.name.type.derive.typesugar"
          ],
          "bindVariable": [
            "variable.other.bind.typesugar"
          ],
          "comptimeBlock": [
            "entity.name.function.comptime.typesugar"
          ]
        }
      },
      {
        "language": "sugared-typescript",
        "scopes": {
          "macro": [
            "entity.name.function.macro.typesugar"
          ],
          "macroDecorator": [
            "entity.name.function.decorator.macro.typesugar"
          ],
          "macroTemplate": [
            "entity.name.tag.macro.typesugar"
          ],
          "extensionMethod": [
            "entity.name.function.extension.typesugar"
          ],
          "deriveArg": [
            "entity.name.type.derive.typesugar"
          ],
          "bindVariable": [
            "variable.other.bind.typesugar"
          ],
          "comptimeBlock": [
            "entity.name.function.comptime.typesugar"
          ]
        }
      },
      {
        "language": "sugared-typescriptreact",
        "scopes": {
          "macro": [
            "entity.name.function.macro.typesugar"
          ],
          "macroDecorator": [
            "entity.name.function.decorator.macro.typesugar"
          ],
          "macroTemplate": [
            "entity.name.tag.macro.typesugar"
          ],
          "extensionMethod": [
            "entity.name.function.extension.typesugar"
          ],
          "deriveArg": [
            "entity.name.type.derive.typesugar"
          ],
          "bindVariable": [
            "variable.other.bind.typesugar"
          ],
          "comptimeBlock": [
            "entity.name.function.comptime.typesugar"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "macro": {
            "foreground": "#C586C0",
            "bold": true
          },
          "macroDecorator": {
            "foreground": "#DCDCAA",
            "bold": true
          },
          "macroTemplate": {
            "foreground": "#CE9178",
            "italic": true
          },
          "extensionMethod": {
            "foreground": "#4EC9B0",
            "italic": true
          },
          "deriveArg": {
            "foreground": "#4FC1FF"
          },
          "bindVariable": {
            "foreground": "#9CDCFE",
            "bold": true
          },
          "comptimeBlock": {
            "fontStyle": "italic"
          }
        }
      }
    },
    "commands": [
      {
        "command": "typesugar.expandMacro",
        "title": "typesugar: Expand Macro at Cursor"
      },
      {
        "command": "typesugar.showTransformed",
        "title": "typesugar: Show Transformed Source"
      },
      {
        "command": "typesugar.refreshManifest",
        "title": "typesugar: Refresh Macro Manifest"
      },
      {
        "command": "typesugar.generateManifest",
        "title": "typesugar: Generate Macro Manifest"
      }
    ],
    "typescriptServerPlugins": [
      {
        "name": "@typesugar/ts-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ],
    "configuration": {
      "title": "typesugar",
      "properties": {
        "typesugar.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens with macro expansion previews"
        },
        "typesugar.enableInlayHints": {
          "type": "boolean",
          "default": true,
          "description": "Show inlay hints for bind types and comptime results"
        },
        "typesugar.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Run background macro expansion for diagnostics"
        },
        "typesugar.manifestPath": {
          "type": "string",
          "default": "typesugar.manifest.json",
          "description": "Path to the macro manifest file (relative to workspace root)"
        },
        "typesugar.useLegacyPlugin": {
          "type": "boolean",
          "default": false,
          "description": "Use legacy language service plugin (error suppression instead of full transformation)"
        },
        "typesugar.enableVerboseLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose logging for the language service plugin (useful for debugging)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vscode-test",
    "test:watch": "vitest",
    "prepackage": "node scripts/bundle-ts-plugin.js",
    "package": "vsce package --no-dependencies && node scripts/inject-ts-plugin.js",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@typesugar/core": "workspace:*",
    "@typesugar/lsp-server": "workspace:*",
    "@typesugar/ts-plugin": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "bundledDependencies": [
    "@typesugar/lsp-server",
    "@typesugar/ts-plugin"
  ],
  "sideEffects": true
}
