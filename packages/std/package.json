{
  "name": "@typesugar/std",
  "version": "0.1.1",
  "description": "🧊 Standard typeclasses and extension methods for enriching basic TypeScript types",
  "author": "Dean Povey <dean.povey@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/typesugar/typesugar.git",
    "directory": "packages/std"
  },
  "homepage": "https://github.com/typesugar/typesugar/tree/main/packages/std#readme",
  "bugs": {
    "url": "https://github.com/typesugar/typesugar/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./typeclasses": {
      "types": "./dist/typeclasses/index.d.ts",
      "import": "./dist/typeclasses/index.js",
      "require": "./dist/typeclasses/index.cjs"
    },
    "./typeclasses/flatmap": {
      "types": "./dist/typeclasses/flatmap.d.ts",
      "import": "./dist/typeclasses/flatmap.js",
      "require": "./dist/typeclasses/flatmap.cjs"
    },
    "./extensions": {
      "types": "./dist/extensions/index.d.ts",
      "import": "./dist/extensions/index.js",
      "require": "./dist/extensions/index.cjs"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js",
      "require": "./dist/data/index.cjs"
    },
    "./macros": {
      "types": "./dist/macros/index.d.ts",
      "import": "./dist/macros/index.js",
      "require": "./dist/macros/index.cjs"
    },
    "./syntax/eq": {
      "types": "./dist/syntax/eq.d.ts",
      "import": "./dist/syntax/eq.js",
      "require": "./dist/syntax/eq.cjs"
    },
    "./syntax/eq/ops": {
      "types": "./dist/syntax/eq/ops.d.ts",
      "import": "./dist/syntax/eq/ops.js",
      "require": "./dist/syntax/eq/ops.cjs"
    },
    "./syntax/ord": {
      "types": "./dist/syntax/ord.d.ts",
      "import": "./dist/syntax/ord.js",
      "require": "./dist/syntax/ord.cjs"
    },
    "./syntax/ord/ops": {
      "types": "./dist/syntax/ord/ops.d.ts",
      "import": "./dist/syntax/ord/ops.js",
      "require": "./dist/syntax/ord/ops.cjs"
    },
    "./syntax/semigroup": {
      "types": "./dist/syntax/semigroup.d.ts",
      "import": "./dist/syntax/semigroup.js",
      "require": "./dist/syntax/semigroup.cjs"
    },
    "./syntax/semigroup/ops": {
      "types": "./dist/syntax/semigroup/ops.d.ts",
      "import": "./dist/syntax/semigroup/ops.js",
      "require": "./dist/syntax/semigroup/ops.cjs"
    },
    "./syntax/monoid": {
      "types": "./dist/syntax/monoid.d.ts",
      "import": "./dist/syntax/monoid.js",
      "require": "./dist/syntax/monoid.cjs"
    },
    "./syntax/monoid/ops": {
      "types": "./dist/syntax/monoid/ops.d.ts",
      "import": "./dist/syntax/monoid/ops.js",
      "require": "./dist/syntax/monoid/ops.cjs"
    },
    "./syntax/group": {
      "types": "./dist/syntax/group.d.ts",
      "import": "./dist/syntax/group.js",
      "require": "./dist/syntax/group.cjs"
    },
    "./syntax/group/ops": {
      "types": "./dist/syntax/group/ops.d.ts",
      "import": "./dist/syntax/group/ops.js",
      "require": "./dist/syntax/group/ops.cjs"
    },
    "./syntax/numeric": {
      "types": "./dist/syntax/numeric.d.ts",
      "import": "./dist/syntax/numeric.js",
      "require": "./dist/syntax/numeric.cjs"
    },
    "./syntax/numeric/ops": {
      "types": "./dist/syntax/numeric/ops.d.ts",
      "import": "./dist/syntax/numeric/ops.js",
      "require": "./dist/syntax/numeric/ops.cjs"
    },
    "./syntax/integral": {
      "types": "./dist/syntax/integral.d.ts",
      "import": "./dist/syntax/integral.js",
      "require": "./dist/syntax/integral.cjs"
    },
    "./syntax/integral/ops": {
      "types": "./dist/syntax/integral/ops.d.ts",
      "import": "./dist/syntax/integral/ops.js",
      "require": "./dist/syntax/integral/ops.cjs"
    },
    "./syntax/fractional": {
      "types": "./dist/syntax/fractional.d.ts",
      "import": "./dist/syntax/fractional.js",
      "require": "./dist/syntax/fractional.cjs"
    },
    "./syntax/fractional/ops": {
      "types": "./dist/syntax/fractional/ops.d.ts",
      "import": "./dist/syntax/fractional/ops.js",
      "require": "./dist/syntax/fractional/ops.cjs"
    },
    "./syntax/clone": {
      "types": "./dist/syntax/clone.d.ts",
      "import": "./dist/syntax/clone.js",
      "require": "./dist/syntax/clone.cjs"
    },
    "./syntax/debug": {
      "types": "./dist/syntax/debug.d.ts",
      "import": "./dist/syntax/debug.js",
      "require": "./dist/syntax/debug.cjs"
    },
    "./syntax/default": {
      "types": "./dist/syntax/default.d.ts",
      "import": "./dist/syntax/default.js",
      "require": "./dist/syntax/default.cjs"
    },
    "./syntax/json": {
      "types": "./dist/syntax/json.d.ts",
      "import": "./dist/syntax/json.js",
      "require": "./dist/syntax/json.cjs"
    },
    "./syntax/type-guard": {
      "types": "./dist/syntax/type-guard.d.ts",
      "import": "./dist/syntax/type-guard.js",
      "require": "./dist/syntax/type-guard.cjs"
    },
    "./syntax/do": {
      "types": "./dist/syntax/do.d.ts",
      "import": "./dist/syntax/do.js",
      "require": "./dist/syntax/do.cjs"
    }
  },
  "typesugar": {
    "macros": "./macros"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "typescript",
    "macros",
    "standard-library",
    "typeclasses",
    "extension-methods",
    "typesugar"
  ],
  "dependencies": {
    "@typesugar/core": "workspace:*",
    "@typesugar/macros": "workspace:*",
    "@typesugar/typeclass": "workspace:*",
    "@typesugar/type-system": "workspace:*"
  },
  "devDependencies": {
    "unplugin-typesugar": "workspace:*"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": true
}
