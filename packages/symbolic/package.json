{
  "name": "@typesugar/symbolic",
  "version": "0.1.0",
  "description": "🧊 Type-safe symbolic mathematics with AST, rendering, evaluation, calculus, and simplification",
  "author": "Dean Povey <dean.povey@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/typesugar/typesugar.git",
    "directory": "packages/symbolic"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@typesugar/macros": "workspace:*",
    "@typesugar/std": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "typesugar",
    "symbolic",
    "math",
    "calculus",
    "differentiation",
    "integration",
    "simplification",
    "latex",
    "cas"
  ],
  "sideEffects": false
}
