{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "typesugar Preset",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "plugins": [
      { "transform": "@typesugar/transformer" }
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.sts",
    "src/**/*.stsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
