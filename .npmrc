access=public
# Hoist ts-plugin so TypeScript language service can find it
public-hoist-pattern[]=@typesugar/ts-plugin
# NPM auth for publishing is configured by actions/setup-node@v4
# (registry-url) in .github/workflows/release.yml — it writes the
# _authToken=${NODE_AUTH_TOKEN} line into the runner's user .npmrc.
# Adding it here causes a pnpm warning locally when the env var is unset.
